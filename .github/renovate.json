{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": ["config:base"],
  "packageRules": [
    {
      "matchUpdateTypes": ["minor", "patch", "pin", "digest"],
      "automerge": true
    },
    {
      "matchDepTypes": ["devDependencies"],
      "automerge": true
    }
  ],
  "schedule": ["every weekend"],
  "labels": ["dependencies"],
  "commitMessagePrefix": "chore(deps):",
  "prHourlyLimit": 2,
  "prConcurrentLimit": 10,
  "rangeStrategy": "pin"
}
